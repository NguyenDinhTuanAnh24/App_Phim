generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MovieStatus {
  NOW_SHOWING
  COMING_SOON
}

enum RoomType {
  STANDARD
  IMAX
  FOUR_DX  @map("4DX")
}

enum SeatType {
  STANDARD
  VIP
  COUPLE
  DISABLED
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum PaymentMethod {
  VNPAY
  MOMO
  CASH
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum DiscountType {
  PERCENT
  FIXED
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  phone          String?      @unique
  password_hash  String
  name           String
  avatar_url     String?
  role           Role         @default(USER)
  loyalty_points Int          @default(0)
  loyalty_tier   String       @default("Đồng")
  refresh_token  String?
  is_verified    Boolean      @default(false)
  date_of_birth  DateTime?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @default(now()) @updatedAt
  bookings       Booking[]
  loyalty_logs   LoyaltyLog[]

  @@map("users")
}

model LoyaltyLog {
  id          String   @id @default(cuid())
  user_id     String
  points      Int // dương = cộng, âm = trừ
  type        String // 'EARN' | 'REDEEM' | 'EXPIRE'
  description String
  booking_id  String?
  created_at  DateTime @default(now())
  user        User     @relation(fields: [user_id], references: [id])

  @@map("loyalty_logs")
}

model Movie {
  id             String      @id @default(cuid())
  tmdb_id        Int         @unique
  title          String
  original_title String
  overview       String      @db.Text
  poster_url     String
  backdrop_url   String
  trailer_key    String?
  genres         Json
  cast           Json
  director       String
  duration       Int
  rating         Float
  language       String
  status         MovieStatus
  release_date   DateTime
  showtimes      Showtime[]

  @@map("movies")
}

model Cinema {
  id        String  @id @default(cuid())
  name      String
  address   String
  city      String
  lat       Float
  lng       Float
  image_url String?
  rooms     Room[]

  @@map("cinemas")
}

model Room {
  id         String     @id @default(cuid())
  cinema_id  String
  cinema     Cinema     @relation(fields: [cinema_id], references: [id])
  name       String
  type       RoomType
  total_rows Int
  total_cols Int
  seats      Seat[]
  showtimes  Showtime[]

  @@map("rooms")
}

model Seat {
  id            String        @id @default(cuid())
  room_id       String
  room          Room          @relation(fields: [room_id], references: [id])
  row           String
  col           Int
  type          SeatType
  booking_items BookingItem[]

  @@unique([room_id, row, col])
  @@map("seats")
}

model Showtime {
  id           String    @id @default(cuid())
  movie_id     String
  movie        Movie     @relation(fields: [movie_id], references: [id])
  room_id      String
  room         Room      @relation(fields: [room_id], references: [id])
  start_time   DateTime
  end_time     DateTime
  price        Int
  vip_price    Int
  couple_price Int
  language     String
  format       String
  bookings     Booking[]

  @@map("showtimes")
}

model Booking {
  id            String        @id @default(cuid())
  user_id       String
  user          User          @relation(fields: [user_id], references: [id])
  showtime_id   String
  showtime      Showtime      @relation(fields: [showtime_id], references: [id])
  status        BookingStatus @default(PENDING)
  total_amount  Int
  qr_code       String        @unique
  qr_image_url  String?
  paid_at       DateTime?
  created_at    DateTime      @default(now())
  expires_at    DateTime
  booking_items BookingItem[]
  payment       Payment?
  food_items    FoodItem[]

  @@map("bookings")
}

model BookingItem {
  id          String  @id @default(cuid())
  booking_id  String
  booking     Booking @relation(fields: [booking_id], references: [id])
  seat_id     String
  seat        Seat    @relation(fields: [seat_id], references: [id])
  price       Int
  showtime_id String

  @@unique([booking_id, seat_id])
  @@map("booking_items")
}

model Payment {
  id             String        @id @default(cuid())
  booking_id     String        @unique
  booking        Booking       @relation(fields: [booking_id], references: [id])
  method         PaymentMethod
  amount         Int
  status         PaymentStatus @default(PENDING)
  transaction_id String?
  vnpay_data     String?       @db.Text
  created_at     DateTime      @default(now())

  @@map("payments")
}

model FoodCombo {
  id          String     @id @default(cuid())
  name        String
  description String
  price       Int
  image_url   String
  food_items  FoodItem[]

  @@map("food_combos")
}

model FoodItem {
  id         String    @id @default(cuid())
  booking_id String
  booking    Booking   @relation(fields: [booking_id], references: [id])
  combo_id   String
  combo      FoodCombo @relation(fields: [combo_id], references: [id])
  quantity   Int
  price      Int

  @@map("food_items")
}

model Voucher {
  id             String       @id @default(cuid())
  code           String       @unique
  discount_type  DiscountType
  discount_value Int
  min_amount     Int          @default(0)
  max_discount   Int?
  usage_limit    Int
  used_count     Int          @default(0)
  expires_at     DateTime

  @@map("vouchers")
}
